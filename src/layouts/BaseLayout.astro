---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import type { NavKey } from "../site/nav";

interface Props {
  title: string;
  description: string;
  active: NavKey;
  keywords?: string;
  footerExtended?: boolean;
}

const { title, description, active, keywords, footerExtended } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500&family=Outfit:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <div class="bg-mesh" aria-hidden="true"></div>
    <div class="grid-overlay" aria-hidden="true"></div>
    <SiteHeader active={active} />
    <slot />
    <SiteFooter extended={footerExtended} />
    <script src="/js/main.js" is:inline></script>
  </body>
</html>
