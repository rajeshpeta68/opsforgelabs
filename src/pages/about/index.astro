---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About | OpsForge Labs"
  description="OpsForge Labs — a software and AI engineering company offering services, consulting, staffing, and hands-on DevOps & AI training."
  active="about"
  keywords="software company, AI engineering, cloud consulting, DevOps training, technology partner"
>
  <main>
    <header class="page-hero">
      <div class="container">
        <p class="section-label">About OpsForge Labs</p>
        <h1>Engineering partner for <span class="gradient-text">modern enterprises</span></h1>
        <p>
          OpsForge Labs helps organizations ship reliable software, adopt AI with discipline, and scale
          platforms — without sacrificing operational sanity. Alongside delivery and advisory, we run an
          academy focused on production-grade DevOps and AI operations so teams build lasting
          capability.
        </p>
      </div>
    </header>

    <section>
      <div class="container">
        <header class="section-header">
          <h2 class="section-title">What we stand for</h2>
          <p class="section-desc">
            Practical outcomes over buzzwords — whether we’re building products, staffing squads, or
            training your engineers.
          </p>
        </header>
        <div class="cards-grid">
          <article class="card">
            <h3>Delivery you can operate</h3>
            <p>Architectures and pipelines designed for ownership, observability, and safe change.</p>
          </article>
          <article class="card">
            <h3>AI with guardrails</h3>
            <p>Use cases grounded in data, security, and measurable ROI — not pilots that stall.</p>
          </article>
          <article class="card">
            <h3>Consulting that respects your culture</h3>
            <p>Roadmaps and reviews that fit how your teams already work — and evolve them.</p>
          </article>
          <article class="card">
            <h3>Talent &amp; training together</h3>
            <p>Staffing when you need capacity; academy programs when you need depth.</p>
          </article>
        </div>
      </div>
    </section>

    <section>
      <div class="container two-col">
        <div>
          <p class="section-label">Vision</p>
          <h2 class="section-title">Trusted partner for software, AI, and cloud</h2>
          <p class="section-desc mt-0">
            To be the team leaders call when they need serious engineering — from first release to
            long-term platform health.
          </p>
        </div>
        <div>
          <p class="section-label">Mission</p>
          <ul class="list-check">
            <li>Deliver high-quality software and platform outcomes</li>
            <li>Apply AI where it creates durable value</li>
            <li>Advise with clarity at executive and engineering levels</li>
            <li>Place and upskill talent through OpsForge Academy</li>
          </ul>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <div class="cta-band">
          <h2>Explore how we can help</h2>
          <p>Services, staffing, or training — tell us what you’re solving.</p>
          <a href="/services/" class="btn btn-secondary btn-lg" style="margin-right:0.5rem">Services</a>
          <a href="/contact/" class="btn btn-primary btn-lg">Contact</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
