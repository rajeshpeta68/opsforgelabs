---
import BaseLayout from "../layouts/BaseLayout.astro";
import { coursesForHome } from "../data/courses";

const homeCourses = coursesForHome();
---

<BaseLayout
  title="OpsForge Labs | Real-World DevOps & AI Engineering Academy"
  description="OpsForge Labs — Real-world DevOps & AI engineering academy. Production-grade Kubernetes, cloud, Linux, automation, and AI-powered operations."
  keywords="DevOps training, Kubernetes, AI DevOps, enterprise engineering, production troubleshooting"
  active="home"
  footerExtended={true}
>
  <main>
    <section class="hero">
      <div class="container">
        <p class="hero-badge">
          <span class="dot" aria-hidden="true"></span> Premium DevOps + AI engineering academy
        </p>
        <h1><span class="gradient-text">OpsForge Labs</span></h1>
        <p class="hero-lead">
          Real-World DevOps &amp; AI Engineering Academy — learn production-grade DevOps, Kubernetes,
          cloud, Linux, automation, and AI-powered operations through real enterprise scenarios.
        </p>
        <div class="hero-actions">
          <a href="/courses/" class="btn btn-primary btn-lg">Explore Courses</a>
          <a href="/contact/" class="btn btn-secondary btn-lg">Join Community</a>
          <a href="/contact/" class="btn btn-outline btn-lg">Book Free Demo</a>
        </div>

        <div class="hero-visual" aria-hidden="true">
          <div class="terminal-bar">
            <div class="terminal-dots"><span></span><span></span><span></span></div>
            <span>opsforge — kubectl · pipeline · aiops</span>
          </div>
          <div class="terminal-body">
            <span class="prompt">student@opsforge:~$</span>
            <span class="cmd">kubectl get pods -n prod</span><br />
            <span class="hl">NAME</span>
            <span class="hl">READY</span>
            <span class="hl">STATUS</span>
            <span class="hl">RESTARTS</span><br />
            api-gateway-7d9ff     2/2     Running     0<br />
            worker-batch-a      1/2     <span style="color:#fbbf24">CrashLoopBackOff</span>   12<br />
            <span class="prompt">student@opsforge:~$</span>
            <span class="cmd"># trace CI/CD, logs, helm rollback — in the lab</span>
          </div>
        </div>
      </div>
    </section>

    <section id="why">
      <div class="container">
        <header class="section-header">
          <p class="section-label">Why OpsForge Labs</p>
          <h2 class="section-title">Built for the AI era</h2>
          <p class="section-desc">
            Most institutes teach outdated theory. At OpsForge Labs, we focus on what modern teams
            actually ship and operate.
          </p>
        </header>
        <div class="cards-grid">
          <article class="card">
            <div class="icon-tag" aria-hidden="true">⚡</div>
            <h3>Real-world troubleshooting</h3>
            <p>Diagnose failures the way production engineers do — not textbook answers.</p>
          </article>
          <article class="card">
            <div class="icon-tag" aria-hidden="true">🏗</div>
            <h3>Enterprise deployment workflows</h3>
            <p>CI/CD, releases, rollbacks, and environments modeled on real pipelines.</p>
          </article>
          <article class="card">
            <div class="icon-tag" aria-hidden="true">🤖</div>
            <h3>AI-assisted operations</h3>
            <p>Use AI thoughtfully for automation, triage, and ops workflows.</p>
          </article>
          <article class="card">
            <div class="icon-tag" aria-hidden="true">🎯</div>
            <h3>Production-ready engineering</h3>
            <p>Skills that transfer directly to on-call, incidents, and shipping features.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="different">
      <div class="container">
        <header class="section-header">
          <p class="section-label">What makes us different</p>
          <h2 class="section-title">Enterprise depth, hands-on by default</h2>
        </header>
        <div class="cards-grid">
          <article class="card">
            <h3>Real enterprise experience</h3>
            <p>
              Learn from engineers with production and infrastructure experience — not slides-only
              instructors.
            </p>
          </article>
          <article class="card">
            <h3>Hands-on labs</h3>
            <p>
              Practice deployment scenarios, CI/CD pipelines, Kubernetes clusters, monitoring, and
              automation.
            </p>
          </article>
          <article class="card">
            <h3>AI + DevOps integration</h3>
            <p>
              Understand how AI is transforming infrastructure operations and how to apply it
              responsibly.
            </p>
          </article>
          <article class="card">
            <h3>Interview &amp; career focus</h3>
            <p>Prepare for real DevOps interviews and production troubleshooting rounds.</p>
          </article>
        </div>
      </div>
    </section>

    <section id="tracks">
      <div class="container">
        <header class="section-header">
          <p class="section-label">Curriculum</p>
          <h2 class="section-title">Core learning tracks</h2>
        </header>
        {
          homeCourses.map((c, i) => (
            <div class="track-item">
              <span class="track-num">{i + 1}</span>
              <div>
                <h4>{c.homeTitle ?? c.title}</h4>
                <p>{c.homeTeaser ?? c.summary}</p>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section id="labs">
      <div class="container">
        <div class="two-col">
          <div>
            <header class="section-header">
              <p class="section-label">Real-world labs</p>
              <h2 class="section-title">Learn beyond tutorials</h2>
              <p class="section-desc mt-0">
                Students work on scenarios that mirror production — not copy-paste demos.
              </p>
            </header>
          </div>
          <ul class="list-check">
            <li>Deployment failures</li>
            <li>Kubernetes troubleshooting</li>
            <li>CI/CD debugging</li>
            <li>Monitoring &amp; alerting</li>
            <li>Infrastructure automation</li>
            <li>Upgrade scenarios</li>
            <li>Rollback simulations</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="vision">
      <div class="container">
        <header class="section-header">
          <p class="section-label">Future vision</p>
          <h2 class="section-title">The future of engineering is AI-assisted operations</h2>
          <p class="section-desc">
            Companies increasingly need engineers who can automate infrastructure, operate
            cloud-native systems, use AI tools effectively, and solve production problems fast.
            OpsForge Labs prepares engineers for that future.
          </p>
        </header>
      </div>
    </section>

    <section id="testimonials">
      <div class="container">
        <header class="section-header">
          <p class="section-label">Voices from the cohort</p>
          <h2 class="section-title">Testimonials</h2>
          <p class="section-desc">Placeholder quotes — add real testimonials as you collect them.</p>
        </header>
        <div class="testimonial-grid">
          <figure class="testimonial">
            <blockquote>“Real-world practical sessions unlike generic training institutes.”</blockquote>
            <cite>— Placeholder learner</cite>
          </figure>
          <figure class="testimonial">
            <blockquote>“Production troubleshooting experience was extremely valuable.”</blockquote>
            <cite>— Placeholder learner</cite>
          </figure>
        </div>
      </div>
    </section>

    <section id="cta" aria-labelledby="cta-heading">
      <div class="container">
        <div class="cta-band">
          <h2 id="cta-heading">Start building production-ready skills</h2>
          <p>Join OpsForge Labs and prepare for modern DevOps &amp; AI engineering careers.</p>
          <a href="/contact/" class="btn btn-primary btn-lg">Join Upcoming Batch</a>
        </div>
      </div>
    </section>

    <section id="lead">
      <div class="container">
        <header class="section-header text-center">
          <p class="section-label">Lead capture</p>
          <h2 class="section-title">Tell us what you’re aiming for</h2>
          <p class="section-desc" style="margin-inline: auto;">
            No backend required for V1 — submitting opens your email client with a prefilled message to
            <strong style="color:var(--text)">rajesh@opsforgelabs.in</strong>.
          </p>
        </header>
        <div style="max-width: 520px; margin-inline: auto;">
          <form id="lead-form" class="contact-card">
            <div class="form-group">
              <label for="lead-name">Name</label>
              <input id="lead-name" name="name" type="text" autocomplete="name" required placeholder="Your name" />
            </div>
            <div class="form-group">
              <label for="lead-email">Email</label>
              <input
                id="lead-email"
                name="email"
                type="email"
                autocomplete="email"
                required
                placeholder="you@company.com"
              />
            </div>
            <div class="form-group">
              <label for="lead-interest">Interest</label>
              <select id="lead-interest" name="interest">
                <option value="Upcoming batch">Upcoming batch</option>
                <option value="Corporate / workshop">Corporate / workshop</option>
                <option value="Consulting">Consulting</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="lead-message">Message</label>
              <textarea id="lead-message" name="message" placeholder="Goals, timeline, background…"
              ></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%">Send via email</button>
            <p class="form-hint">Wire this form to Formspree, Netlify Forms, or your CRM when you’re ready.</p>
          </form>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
