---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { blogTopics } from "../../data/blog-topics";
---

<BaseLayout
  title="Blog | OpsForge Labs"
  description="OpsForge Labs — insights on software delivery, AI in operations, Kubernetes, CI/CD, and engineering leadership."
  active="blog"
  keywords="DevOps blog, AI operations, Kubernetes, software engineering"
>
  <main>
    <header class="page-hero">
      <div class="container">
        <p class="section-label">Blog</p>
        <h1>Ideas for <span class="gradient-text">upcoming articles</span></h1>
        <p>
          Topic list is easy to edit in the codebase; replace with real articles when you publish.
        </p>
      </div>
    </header>

    <section>
      <div class="container blog-list">
        {
          blogTopics.map((post) => (
            <article class="blog-row">
              <div>
                <h3>{post.title}</h3>
                <p>{post.description}</p>
              </div>
              <span class="blog-tag">{post.status}</span>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
